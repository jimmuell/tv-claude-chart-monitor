{
  "name": "trading-analyzer",
  "version": "0.1.0",
  "description": "TradingView chart analysis menubar app",
  "main": "dist/main/index.js",
  "private": true,
  "scripts": {
    "dev": "tsc -p tsconfig.main.json && concurrently -k -n \"MAIN,VITE,APP\" -c \"cyan,yellow,green\" \"tsc -w -p tsconfig.main.json\" \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "tsc -p tsconfig.main.json && vite build",
    "package": "npm run build && electron-builder"
  },
  "dependencies": {
    "menubar": "^9.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "wait-on": "^7.2.0"
  }
}
